# ─────────────────────────────────────────────
#  MUTAAFI RAG Chatbot — .gitignore
# ─────────────────────────────────────────────

# =============================================
#  SECRETS & ENVIRONMENT VARIABLES
# =============================================
.env
.env.local
.env.*.local
*.env

# =============================================
#  PYTHON
# =============================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.spec

# Virtual environments
venv/
.venv/
env/
ENV/
.Python

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
nosetests.xml
*.cover

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Jupyter Notebooks
.ipynb_checkpoints

# =============================================
#  NODE / JAVASCRIPT (Frontend)
# =============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
frontend/dist/
frontend/build/
frontend/.vite/

# Cache
.cache/
.parcel-cache/
.eslintcache

# =============================================
#  OPERATING SYSTEM
# =============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~

# =============================================
#  IDE / EDITOR FILES
# =============================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# =============================================
#  LOGS
# =============================================
logs/
*.log

# =============================================
#  MISC
# =============================================
*.tmp
*.bak
*.swp
*.swo
